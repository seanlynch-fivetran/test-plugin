{
  "name": "test-plugin",
  "version": "1.2.1",
  "description": "Test plugin with a simple MCP server that reports environment state",
  "author": {
    "name": "Test"
  },
  "userConfig": {
    "test_username": {
      "title": "Test Username",
      "description": "A test username (not secret)",
      "type": "string",
      "sensitive": false
    },
    "test_api_key": {
      "title": "Test API Key",
      "description": "A test API key (secret)",
      "type": "string",
      "sensitive": true
    }
  },
  "mcpServers": {
    "test-mcp": {
      "command": "uv",
      "args": ["run", "--with", "fastmcp", "${CLAUDE_PLUGIN_ROOT}/mcps/test/server.py"],
      "env": {
        "TEST_ENV_VARIABLE": "${TEST_ENV_VARIABLE}",
        "TEST_DEFAULT_VARIABLE": "set in repo",
        "CLAUDE_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "CLAUDE_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
        "TEST_USERNAME": "${user_config.test_username}",
        "TEST_API_KEY": "${user_config.test_api_key}"
      }
    }
  }
}
